{
  "routes": [
    { "route": "/.auth/*", "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/login.html", "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/privacy.html", "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/api/*", "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/*", "allowedRoles": ["anonymous", "authenticated"] }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/.auth/*", "/assets/*", "/data/*", "*.{css,js,json,ico,png,jpg,jpeg,svg,webp,woff,woff2}"]
  },
  "platform": { "apiRuntime": "node:18" }
}
